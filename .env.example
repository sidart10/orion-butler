# Test Environment Configuration
# Copy to .env and fill in values

# Environment
TEST_ENV=local
NODE_ENV=test

# Application URLs
BASE_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# Agent-Browser Configuration
AGENT_BROWSER_HEADLESS=1
# AGENT_BROWSER_EXECUTABLE_PATH=/path/to/chrome
# AGENT_BROWSER_STREAM_PORT=9223

# Authentication (if applicable)
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=

# API Keys (if applicable)
# ANTHROPIC_API_KEY=
# COMPOSIO_API_KEY=

# Observability - Braintrust (session analysis, learning extraction)
# TRACE_TO_BRAINTRUST=true
# BRAINTRUST_API_KEY=
# BRAINTRUST_CC_PROJECT=claude-code

# Observability - Langfuse (prompt management, evaluation, annotations)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
