{
  "name": "orion-personal-butler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:e2e": "tsx tests/support/browser-agent/e2e-runner.ts",
    "test:e2e:headed": "AGENT_BROWSER_HEADLESS=0 tsx tests/support/browser-agent/e2e-runner.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@json-render/core": "^0.2.0",
    "@json-render/react": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "glob": "^11.0.0",
    "shadcn": "^3.6.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
